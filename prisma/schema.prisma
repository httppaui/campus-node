datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

enum Role {
  ADMIN
  OFFICER
  MEMBER
  ALUMNI
  APPLICANT
}

enum ApplicationStatus {
  APPLIED
  SCREENING
  INTERVIEW_SCHEDULED
  OFFERED
  REJECTED
}

enum TaskStatus {
  TODO
  IN_PROGRESS
  UNDER_REVIEW
  DONE
}

enum TaskPriority {
  LOW
  MEDIUM
  HIGH
}

enum DocCategory {
  CONSTITUTION
  SOP
  MINUTES
  TURNOVER
  TEMPLATE
}

enum BudgetType {
  INCOME
  EXPENSE
}

enum LiquidationStatus {
  PENDING
  APPROVED
  REJECTED
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  role          Role      @default(APPLICANT)
  department    String?
  yearLevel     Int?
  course        String?
  isActive      Boolean   @default(true)
  totalPoints   Int       @default(0)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // NextAuth standard fields
  accounts      Account[]
  sessions      Session[]
  
  // Custom Relations
  committeeId   String?
  committee     Committee? @relation(fields: [committeeId], references: [id])
  
  assignedTasks Task[]     @relation("TaskAssignee")
  createdTasks  Task[]     @relation("TaskCreator")
  
  registrations EventRegistration[]
  attendances   Attendance[]
  pointTransactions PointTransaction[] @relation("PointReceiver")
  approvedPoints    PointTransaction[] @relation("PointApprover")
  
  uploadedDocs  Document[]
  applications  Application[]
  liquidations  Liquidation[]
  announcements Announcement[]
  badges        UserBadge[]
}

model Account {
  id                 String  @id @default(cuid())
  userId             String
  type               String
  provider           String
  providerAccountId  String
  refresh_token      String?  @db.Text
  access_token       String?  @db.Text
  expires_at         Int?
  token_type         String?
  scope              String?
  id_token           String?  @db.Text
  session_state      String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Committee {
  id          String   @id @default(cuid())
  name        String   @unique
  description String?
  createdAt   DateTime @default(now())
  
  members     User[]
  tasks       Task[]
  documents   Document[]
}

model Task {
  id          String       @id @default(cuid())
  title       String
  description String?      @db.Text
  status      TaskStatus   @default(TODO)
  priority    TaskPriority @default(MEDIUM)
  dueDate     DateTime?
  deliverable String?      // URL to output
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  committeeId String
  committee   Committee    @relation(fields: [committeeId], references: [id])

  assigneeId  String?
  assignee    User?        @relation("TaskAssignee", fields: [assigneeId], references: [id])
  
  creatorId   String
  creator     User         @relation("TaskCreator", fields: [creatorId], references: [id])
}

model Event {
  id          String   @id @default(cuid())
  title       String
  description String?  @db.Text
  location    String
  startTime   DateTime
  endTime     DateTime
  coverImage  String?
  pointsValue Int      @default(10)
  qrSecret    String   @default(dbgenerated("gen_random_uuid()::text")) // Seeds rotating QR code
  createdAt   DateTime @default(now())

  registrations EventRegistration[]
  attendances   Attendance[]
}

model EventRegistration {
  id            String   @id @default(cuid())
  eventId       String
  userId        String
  rsvpStatus    Boolean  @default(true) // RSVP yes/no
  volunteerRole String?  // Optional volunteer assignment
  registeredAt  DateTime @default(now())

  event Event @relation(fields: [eventId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([eventId, userId])
}

model Attendance {
  id           String    @id @default(cuid())
  eventId      String
  userId       String
  checkInTime  DateTime  @default(now())
  checkOutTime DateTime?
  isManual     Boolean   @default(false)
  verifiedById String?   // Officer user ID who manually checked them in

  event Event @relation(fields: [eventId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([eventId, userId])
}

model PointTransaction {
  id          String   @id @default(cuid())
  userId      String   // Receiver
  points      Int
  reason      String
  approvedById String? // Officer/Admin
  createdAt   DateTime @default(now())

  user       User  @relation("PointReceiver", fields: [userId], references: [id], onDelete: Cascade)
  approvedBy User? @relation("PointApprover", fields: [approvedById], references: [id])
}

model Document {
  id          String      @id @default(cuid())
  title       String
  url         String
  category    DocCategory @default(SOP)
  tags        String[]    // Search tags
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  committeeId String?
  committee   Committee?  @relation(fields: [committeeId], references: [id])

  uploaderId  String
  uploader    User        @relation(fields: [uploaderId], references: [id])
}

model Application {
  id           String            @id @default(cuid())
  userId       String
  status       ApplicationStatus @default(APPLIED)
  formResponse Json              // Dynamic responses
  reviewNotes  String?           @db.Text
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Liquidation {
  id           String            @id @default(cuid())
  userId       String            // Person submitting
  amount       Decimal           @db.Decimal(10, 2)
  description  String
  receiptUrl   String
  status       LiquidationStatus @default(PENDING)
  reviewedById String?
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt

  user User @relation(fields: [userId], references: [id])
}

model Announcement {
  id             String   @id @default(cuid())
  title          String
  content        String   @db.Text
  isPinned       Boolean  @default(false)
  isAlumniTarget Boolean  @default(false)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  authorId String
  author   User     @relation(fields: [authorId], references: [id])
}

model Badge {
  id          String      @id @default(cuid())
  name        String      @unique
  description String
  iconUrl     String
  pointsLimit Int         @default(0) // Point threshold to unlock

  users UserBadge[]
}

model UserBadge {
  id        String   @id @default(cuid())
  userId    String
  badgeId   String
  unlockedAt DateTime @default(now())

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  badge Badge @relation(fields: [badgeId], references: [id], onDelete: Cascade)

  @@unique([userId, badgeId])
}
